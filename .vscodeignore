# Source files (we use bundled dist/)
src/**
!src/dashboard/webview/**

# Development files
.vscode/**
.gitignore
tsconfig.json
esbuild.js
*.md
!readme.md

# Test files
**/*.test.ts
**/test/**

# Build artifacts
*.vsix

# First, exclude all node_modules (matches .gitignore)
node_modules/**

# Then explicitly include node-pty
!node_modules/node-pty/
!node_modules/node-pty/**

# Exclude node-pty dev files we don't need
node_modules/node-pty/src/**
node_modules/node-pty/deps/**
node_modules/node-pty/scripts/**
node_modules/node-pty/third_party/**
node_modules/node-pty/*.md
node_modules/node-pty/binding.gyp
node_modules/node-pty/**/*.test.js
node_modules/node-pty/**/*.test.js.map
