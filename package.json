{
  "name": "xerebro-vscode",
  "displayName": "Operator",
  "description": "MCP server that enables AI assistants to control VS Code",
  "version": "0.1.9",
  "publisher": "xerebro",
  "repository": {
    "type": "git",
    "url": "https://github.com/iprado/cerebroapp-monorepo"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-mcp-server.start",
        "title": "MCP Server: Start"
      },
      {
        "command": "vscode-mcp-server.stop",
        "title": "MCP Server: Stop"
      },
      {
        "command": "vscode-mcp-server.toggle",
        "title": "MCP Server: Toggle"
      },
      {
        "command": "vscode-mcp-server.openDashboard",
        "title": "Open Operator",
        "icon": "$(layout)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xerebroOperator",
          "title": "Xerebro",
          "icon": "resources/ai-agent-icon.svg"
        }
      ]
    },
    "views": {
      "xerebroOperator": [
        {
          "id": "xerebroLauncherView",
          "name": "Open Dashboard",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vscode-mcp-server.openDashboard",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "VS Code MCP Server",
      "properties": {
        "vscode-mcp-server.port": {
          "type": "number",
          "default": 9002,
          "description": "Port for the MCP server"
        },
        "vscode-mcp-server.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host address for the MCP server (localhost only for security)"
        },
        "vscode-mcp-server.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the server when VS Code opens"
        },
        "vscode-mcp-server.autoNaming": {
          "type": "object",
          "default": {
            "enabled": true,
            "commandThreshold": 3,
            "model": "x-ai/grok-4.1-fast"
          },
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable AI-powered automatic terminal naming"
            },
            "commandThreshold": {
              "type": "number",
              "default": 3,
              "minimum": 1,
              "maximum": 10,
              "description": "Number of commands after which to auto-name the terminal"
            },
            "model": {
              "type": "string",
              "default": "x-ai/grok-4.1-fast",
              "description": "OpenRouter model to use for generating terminal names"
            }
          }
        },
        "vscode-mcp-server.coloredPreviews": {
          "type": "boolean",
          "default": true,
          "description": "Enable ANSI color rendering in terminal previews"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.19.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "zod": "^3.22.0"
  }
}
